{
  "name": "pilot-project",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run prisma:merge && next dev",
    "build": "npm run prisma:merge && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "prisma:merge": "aiden-db-merge-schema",
    "prisma:generate": "npm run prisma:merge && prisma generate",
    "postinstall": "node scripts/postinstall.mjs",
    "db:migrate": "npm run prisma:merge && prisma migrate dev",
    "db:push": "npm run prisma:merge && prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "clean": "rm -rf .next .turbo dist src/generated"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@upstart13-com/aiden-ai": "^2.0.0",
    "@upstart13-com/aiden-auth": "^2.0.0",
    "@upstart13-com/aiden-db": "^2.0.0",
    "@upstart13-com/aiden-logging": "^2.0.0",
    "@upstart13-com/aiden-realtime": "^2.0.0",
    "@upstart13-com/aiden-security": "^2.0.0",
    "@upstart13-com/aiden-ui": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "^16.2.5",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "prisma": "^7.4.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "recharts": "^3.9.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.33",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
