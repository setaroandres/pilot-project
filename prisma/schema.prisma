// ─── prisma\fragments\catalog.prisma ───
// Semantic data catalog — business definitions for every pilot table and column.
//
// Seeded in prisma/seed.ts with ~60 entries covering all three analytics domains.
// Admins can override any entry via PATCH /api/catalog/[id] (assertCan("catalog.manage")).
// All authenticated users can read the catalog (no role gate on GET routes).
//
// columnName is nullable: null means the entry describes the table as a whole
// rather than a specific column.
//
// In Phase 2 this is replaced by an embeddings-backed semantic search store.
// The seeded catalog serves as the source of "did you mean?" suggestions
// in the NL query engine for the pilot.

model CatalogEntry {
  id            String   @id @default(cuid())
  domain        String   // "patient_outcomes" | "operational" | "financial"
  tableName     String   @map("table_name")
  columnName    String?  @map("column_name") // null = table-level entry
  businessLabel String   @map("business_label")
  definition    String   @db.Text
  caveats       String?  @db.Text
  lineage       String?  @db.Text // where the metric comes from / how it's calculated
  isOverride    Boolean  @default(false) @map("is_override") // true = human-curated admin edit
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([domain, tableName, columnName])
  @@index([domain])
  @@map("catalog_entries")
}

// ─── prisma\fragments\conversation.prisma ───
// Conversation sessions and their turns — the NL query history per user.
//
// One Conversation groups multiple ConversationTurns (Q&A pairs).
// The route passes the last N turns as prior messages to the AI client
// to support follow-up questions (up to 10 turns of context).
//
// Both models cascade-delete when the parent is removed:
//   - Conversation deleted → all its turns deleted (ConversationTurn.onDelete: Cascade)
//   - User deleted → all their conversations deleted (Conversation.onDelete: Cascade)
//     which in turn cascade-deletes all turns via the above.

model Conversation {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  title     String             @default("New Conversation")
  domain    String?            // "patient_outcomes" | "operational" | "financial" | null (multi-domain)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  turns ConversationTurn[]

  @@index([userId])
  @@map("conversations")
}

model ConversationTurn {
  id               String   @id @default(cuid())
  conversationId   String   @map("conversation_id")
  userId           String   @map("user_id")
  userQuery        String   @map("user_query")       @db.Text
  querySpec        Json?    @map("query_spec")       // AI-generated, Zod-validated QuerySpec
  chartSpec        Json?    @map("chart_spec")       // { chartType, x, y, series }
  resultMetadata   Json?    @map("result_metadata")  // { rowCount, executionMs } — never raw data
  narrativeSummary String?  @map("narrative_summary") @db.Text
  error            String?
  createdAt        DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([userId])
  @@map("conversation_turns")
}

// ─── prisma\fragments\pin.prisma ───
// Personal pinned visualizations — user's saved dashboard items.
//
// A pin is created from a ConversationTurn: the querySpec, chartSpec, and
// a snapshot of the result rows at pin time are copied over. The pin is
// self-contained — it does not reference the turn by FK so it survives
// conversation deletion.
//
// Only analyst and admin roles can create pins (assertCan("query.run") gate
// on POST /api/pins). Viewer role sees an informational message on the pins
// page instead of this data.
//
// Cascade: User deleted → all their pins deleted.

model PinnedVisualization {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  title          String
  querySpec      Json     @map("query_spec")
  chartSpec      Json     @map("chart_spec")
  resultSnapshot Json?    @map("result_snapshot") // cached result rows at pin time
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("pinned_visualizations")
}

// ─── prisma\fragments\user.prisma ───
// User model — owned by the consumer because Prisma requires it to
// declare every back-relation it participates in. Add your business
// back-refs here (e.g. `posts Post[]`, `org Org @relation(...)`).

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts             Account[]
  sessions             Session[]
  roles                Role[]               @relation("UserRoles")
  conversations        Conversation[]
  pinnedVisualizations PinnedVisualization[]

  @@map("users")
}

